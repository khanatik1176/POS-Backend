# Render production environment template
DEBUG=False
DJANGO_SECRET_KEY=replace_with_strong_secret
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DB_SSL_REQUIRE=True

# Render will also set RENDER_EXTERNAL_HOSTNAME automatically
ALLOWED_HOSTS=your-service-name.onrender.com

CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com,https://your-service-name.onrender.com

TIME_ZONE=Asia/Dhaka

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

TELEGRAM_BOT_ENABLED=True
TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret
TELEGRAM_WEBHOOK_URL=https://your-service-name.onrender.com/api/telegram/webhook/
